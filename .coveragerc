[run]
source = src
omit = 
    */site-packages/*
    */dist-packages/*
    */tests/*
    src/utils/logging_config.py
    */__init__.py
    *\__init__.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    raise ImportError

[html]
directory = coverage_html_report